{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "get-log input",
    "$id": "http://schema.nethserver.org/imapsync/get-log.json",
    "description": "Get the imapsync log for a task",
    "examples": [
        {
            "task_id": "r3koe0",
            "localuser": "john"
        }
    ],
    "type": "object",
    "required": [
        "task_id",
        "localuser"
    ],
    "properties": {
        "task_id": {
            "type": "string",
            "minLength": 1
        },
        "localuser": {
            "type": "string",
            "minLength": 1
        }
    }
}
